{
  "expo": {
    "name": "CapyEnglish",
    "slug": "CapyEnglish",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "capyenglish",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FDEDD9"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.illia_vin.CapyEnglish"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./scripts/with-android-release-optimizations",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FDEDD9",
          "image": "./assets/images/icon.png",
          "imageWidth": 200
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
